# MCP Server Configuration
MCP_ENABLED=true
MCP_PORT=3000
MCP_HOST=localhost
MCP_DEBUG=false
MCP_LOG_LEVEL=info

# Node Environment
NODE_ENV=development

# Skill Configuration
SKILLS_ENABLED=true
PRE_DEPLOY_VALIDATOR_ENABLED=true
FRONTEND_DESIGN_ENABLED=true
THEME_FACTORY_ENABLED=true
MCP_BUILDER_ENABLED=true
SKILL_CREATOR_ENABLED=true
ASCII_MOCKUP_ENABLED=true
ALGORITHMIC_ART_ENABLED=true
CANVAS_DESIGN_ENABLED=true

# Deployment Validation
VALIDATOR_FAIL_ON_WARNING=true
VALIDATOR_ALLOW_UNCOMMITTED=false
VALIDATOR_CHECK_BRANCH_PROTECTION=true

# Frontend Design Configuration
FRONTEND_OUTPUT_DIR=apps/web/src/components
FRONTEND_CSS_FRAMEWORK=tailwind
FRONTEND_INCLUDE_TESTS=true

# Theme Factory Configuration
THEME_OUTPUT_DIR=apps/web/src/themes
THEME_BASE_COLOR=#4F46E5
THEME_GENERATE_TYPOGRAPHY=true
THEME_GENERATE_SPACING=true

# MCP Builder Configuration
MCP_BUILDER_OUTPUT_DIR=tools/mcp/custom
MCP_BUILDER_INCLUDE_TESTS=true
MCP_BUILDER_INCLUDE_DOCS=true

# Skill Creator Configuration
SKILL_CREATOR_OUTPUT_DIR=tools/mcp/custom-skills
SKILL_CREATOR_LANGUAGE=typescript
SKILL_CREATOR_INCLUDE_TESTS=true

# Build and Test Configuration
BUILD_ENABLED=true
TEST_ENABLED=true
LINT_ENABLED=true

# Logging
LOG_DIR=../../logs/mcp
LOG_LEVEL=info
LOG_FORMAT=json

# API Configuration (if needed)
API_BASE_URL=http://localhost:3000
API_TIMEOUT=30000
