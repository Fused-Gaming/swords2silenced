{
  "metadata": {
    "name": "Swords to Silenced Design System",
    "version": "1.0.0",
    "description": "Comprehensive design token system for the advocacy platform",
    "author": "Design Team",
    "lastUpdated": "2026-05-09"
  },
  "color": {
    "primary": {
      "navy": {
        "deep": "#1f0021",
        "light": "#3c0518",
        "xlight": "#2d031d",
        "description": "Primary navy - authority, depth, dark backgrounds"
      },
      "red": {
        "alert": "#751006",
        "dark": "#5D0804",
        "light": "#f5c0b2",
        "description": "Action red - urgency, CTAs, emphasis"
      }
    },
    "semantic": {
      "success": {
        "default": "#2A9D8F",
        "dark": "#1B6B5F",
        "description": "Success states, verified information"
      },
      "warning": {
        "default": "#F77F00",
        "dark": "#B35A00",
        "description": "Warnings, caution states"
      },
      "critical": {
        "default": "#D62828",
        "dark": "#8B1A20",
        "description": "Critical alerts, urgent action needed"
      },
      "info": {
        "default": "#5B8DEF",
        "description": "Information states, additional context"
      }
    },
    "neutral": {
      "white": "#F8F9FA",
      "black": "#1f0021",
      "gray": {
        "light": "#A0A8B8",
        "muted": "#8B7A96",
        "border": "#3c2634",
        "xlight": "#0f0a0d"
      }
    },
    "accessibility": {
      "focus": "#f5c0b2",
      "focusOutline": "2px solid #f5c0b2",
      "contrast": {
        "high": "#1f0021",
        "low": "#8B7A96"
      },
      "wcagAA": true,
      "wcagAAA": true,
      "description": "WCAG AA/AAA compliant color ratios"
    }
  },
  "typography": {
    "fontFamily": {
      "serif": "'Cormorant Garamond', serif",
      "sans": "'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif"
    },
    "fontWeight": {
      "regular": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700
    },
    "typeScale": {
      "hero": {
        "size": "52px",
        "lineHeight": 1.2,
        "letterSpacing": "-0.02em",
        "fontFamily": "serif",
        "fontWeight": 700,
        "mobileSize": "32px"
      },
      "h1": {
        "size": "40px",
        "lineHeight": 1.2,
        "letterSpacing": "-0.02em",
        "fontFamily": "serif",
        "fontWeight": 700,
        "mobileSize": "28px"
      },
      "h2": {
        "size": "30px",
        "lineHeight": 1.3,
        "letterSpacing": "-0.01em",
        "fontFamily": "serif",
        "fontWeight": 700,
        "mobileSize": "24px"
      },
      "h3": {
        "size": "24px",
        "lineHeight": 1.3,
        "letterSpacing": "0",
        "fontFamily": "sans",
        "fontWeight": 600,
        "mobileSize": "20px"
      },
      "h4": {
        "size": "20px",
        "lineHeight": 1.4,
        "letterSpacing": "0",
        "fontFamily": "sans",
        "fontWeight": 600,
        "mobileSize": "18px"
      },
      "body": {
        "size": "16px",
        "lineHeight": 1.5,
        "letterSpacing": "0",
        "fontFamily": "sans",
        "fontWeight": 400,
        "mobileSize": "16px"
      },
      "bodySmall": {
        "size": "14px",
        "lineHeight": 1.5,
        "letterSpacing": "0",
        "fontFamily": "sans",
        "fontWeight": 400,
        "mobileSize": "14px"
      },
      "caption": {
        "size": "12px",
        "lineHeight": 1.4,
        "letterSpacing": "0.04em",
        "fontFamily": "sans",
        "fontWeight": 500,
        "mobileSize": "12px"
      }
    },
    "lineHeight": {
      "tight": 1.2,
      "normal": 1.5,
      "relaxed": 1.8
    },
    "letterSpacing": {
      "tight": "-0.02em",
      "normal": "0",
      "wide": "0.04em"
    }
  },
  "spacing": {
    "description": "8px base unit, mobile-first scaling",
    "xs": "4px",
    "sm": "8px",
    "md": "16px",
    "lg": "24px",
    "xl": "32px",
    "2xl": "48px",
    "3xl": "64px",
    "4xl": "96px"
  },
  "layout": {
    "grid": {
      "columns": 12,
      "gutter": "24px",
      "gutterMobile": "16px"
    },
    "container": {
      "maxWidth": "1280px",
      "padding": "24px",
      "paddingMobile": "16px"
    },
    "breakpoints": {
      "mobile": {
        "value": "320px",
        "description": "Mobile phones, smallest devices"
      },
      "tablet": {
        "value": "768px",
        "description": "Tablets, large phones"
      },
      "desktop": {
        "value": "1024px",
        "description": "Desktop, large screens"
      },
      "wide": {
        "value": "1440px",
        "description": "Wide screens, large displays"
      },
      "ultrawide": {
        "value": "1920px",
        "description": "Ultra-wide displays"
      }
    }
  },
  "shadows": {
    "sm": "0 1px 2px rgba(31, 0, 33, 0.2)",
    "md": "0 2px 4px rgba(31, 0, 33, 0.3)",
    "lg": "0 4px 8px rgba(31, 0, 33, 0.4)",
    "xl": "0 8px 16px rgba(31, 0, 33, 0.5)",
    "none": "none"
  },
  "borders": {
    "radius": {
      "sm": "4px",
      "md": "8px",
      "lg": "12px",
      "xl": "16px",
      "full": "9999px"
    },
    "width": "1px",
    "color": "#3c2634",
    "style": "solid"
  },
  "transitions": {
    "fast": {
      "duration": "100ms",
      "timing": "ease"
    },
    "normal": {
      "duration": "200ms",
      "timing": "ease"
    },
    "slow": {
      "duration": "300ms",
      "timing": "ease"
    },
    "timingFunctions": {
      "easeIn": "cubic-bezier(0.4, 0, 1, 1)",
      "easeOut": "cubic-bezier(0, 0, 0.2, 1)",
      "easeInOut": "cubic-bezier(0.4, 0, 0.2, 1)"
    }
  },
  "zIndex": {
    "dropdown": 1000,
    "sticky": 1050,
    "modal": 2000,
    "tooltip": 3000,
    "notification": 4000,
    "description": "Consistent stacking context"
  },
  "components": {
    "button": {
      "primary": {
        "background": "#751006",
        "color": "#F8F9FA",
        "borderRadius": "8px",
        "padding": "12px 24px",
        "fontSize": "16px",
        "fontWeight": 600,
        "cursor": "pointer",
        "hoverBackground": "#5D0804",
        "focusOutline": "2px solid #f5c0b2",
        "transition": "200ms ease"
      },
      "secondary": {
        "background": "transparent",
        "color": "#751006",
        "border": "2px solid #751006",
        "borderRadius": "8px",
        "padding": "10px 22px",
        "fontSize": "16px",
        "fontWeight": 600,
        "cursor": "pointer",
        "hoverBackground": "rgba(117, 16, 6, 0.05)",
        "focusOutline": "2px solid #f5c0b2",
        "transition": "200ms ease"
      }
    },
    "navigation": {
      "height": "64px",
      "mobileHeight": "56px",
      "background": "#1f0021",
      "textColor": "#F8F9FA",
      "linkHoverColor": "#f5c0b2",
      "mobileBreakpoint": "768px"
    },
    "input": {
      "borderRadius": "8px",
      "borderWidth": "1px",
      "borderColor": "#3c2634",
      "padding": "12px 16px",
      "fontSize": "16px",
      "focusBorder": "#751006",
      "focusOutline": "2px solid #f5c0b2"
    }
  },
  "accessibility": {
    "focusOutline": "2px solid #f5c0b2",
    "focusOffset": "2px",
    "minTouchTarget": "44px",
    "wcag": "AA",
    "contrastRatios": {
      "largeText": "3:1",
      "normalText": "4.5:1",
      "ui": "3:1"
    }
  },
  "darkMode": {
    "enabled": true,
    "default": true,
    "description": "Dark mode is default, light mode opt-in via system preference"
  }
}
